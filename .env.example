# Menu generator — environment variables
# Copy this file to .env and fill in real values. Never commit the filled-in
# version to source control.

# --- OpenAI (used by the "Generate Menu" node) ---
OPENAI_API_KEY=sk-your-openai-api-key

# --- PostgreSQL (used by menu-generator-schema.sql) ---
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=menu_generator
PG_USER=menu_generator_app
PG_PASSWORD=change-me
# Convenience connection string some tools expect instead of the split vars above
DATABASE_URL=postgresql://menu_generator_app:change-me@localhost:5432/menu_generator

# --- n8n ---
# Base URL of your n8n instance, used to build the full webhook URL below
N8N_BASE_URL=https://your-n8n-instance.com
N8N_WEBHOOK_PATH=menu-generator
# Full webhook URL the interface's "Workflow webhook URL" field expects
MENU_GENERATOR_WEBHOOK_URL=https://your-n8n-instance.com/webhook/menu-generator

# Set to "test" to use n8n's test webhook URL (/webhook-test/...) while building,
# or "production" once the workflow is active
N8N_WEBHOOK_MODE=production
